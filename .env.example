# Application
APP_ENV=production
SECRET_KEY=change-this-secret-key
TZ=UTC

# Server
APP_HOST=0.0.0.0
APP_PORT=5000
HOST_PORT=5000

# Authentication mode
# Example values: local, directory, directory_local_roles
AUTH_MODE=local

# Optional directory authentication settings
DIRECTORY_SERVER=
DIRECTORY_BASE_DN=
DIRECTORY_BIND_DN=
DIRECTORY_BIND_PASSWORD=
DIRECTORY_USER_FILTER=

# Runtime settings
SAVE_VEHICLE_IMAGES=1
CAMERA_RECONNECT_SECONDS=10
CAMERA_SNAPSHOT_INTERVAL_SECONDS=2
CAMERA_DEFAULT_CONFIDENCE=0.50

# Data retention
IMAGE_RETENTION_DAYS=30
LOG_RETENTION_DAYS=180

# Uploads
MAX_UPLOAD_MB=20
